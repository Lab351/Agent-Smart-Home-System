# Docker忽略文件
# 防止敏感文件和目录被打包到Docker镜像中

# Python相关
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
*.egg-info/
.pytest_cache/

# 虚拟环境
venv/
ENV/
env/
.venv/

# IDE配置
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# 日志
*.log
logs/

# 数据库
*.db
*.sqlite
*.sqlite3

# 测试
.pytest_cache/
.coverage
htmlcov/
.tox/

# Git
.git/
.gitignore
.gitattributes

# Docker
.dockerignore
Dockerfile
docker-compose*.yml

# 文档和脚本（开发环境）
docs/
scripts/
README.md
*.md

# 配置文件（包含敏感信息）
config/local.yaml
config/*.secrets.yaml

# 数据和缓存
data/
cache/
tmp/
temp/

# 备份
backup/
*.backup
*.bak

# 其他
.DS_Store
Thumbs.db
*.pid
